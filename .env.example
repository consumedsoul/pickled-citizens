# Pickled Citizens — environment variables
#
# Copy to .env.local for local development (.env.local is git-ignored).
# In production these are set as Cloudflare secrets ([vars] for the public
# ones live in wrangler.toml).

# --- Public (safe to expose to the browser; committed in wrangler.toml [vars]) ---

# The public URL where your app is deployed (used for auth redirects).
# Must be https:// in production; use http://localhost:3000 for local dev.
NEXT_PUBLIC_SITE_URL=https://pickledcitizens.com

# Clerk client (publishable) key — safe to commit.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# Clerk auth route configuration.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/signin
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/signup

# --- Server-only (NEVER commit actual values; set as Cloudflare secrets) ---

# Clerk Backend API key.
CLERK_SECRET_KEY=sk_test_your-secret-key-here

# Verifies the Clerk user.created/updated/deleted webhook (svix signature).
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your-webhook-signing-secret-here

# Display timezone for session metadata (default: America/Los_Angeles).
# Must be a valid IANA timezone string: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples: America/New_York, America/Chicago, America/Denver, Europe/London, Asia/Tokyo
DISPLAY_TIMEZONE=America/Los_Angeles
